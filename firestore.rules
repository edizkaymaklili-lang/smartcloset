rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - authenticated users can read any profile, but only write their own
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Wardrobe items - users can only access their own items
    match /wardrobe/{itemId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Outfits - users can only access their own outfits
    match /outfits/{outfitId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Style recommendations - users can only access their own recommendations
    match /recommendations/{recommendationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Style Feed posts - anyone can read, only owner can write/delete
    match /style_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Comments - anyone can read, authenticated users can create, only owner can delete
    match /style_posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Likes - anyone can read, authenticated users can create/delete their own likes
    match /style_posts/{postId}/likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Saved posts - users can only access their own saved posts
    match /users/{userId}/saved_posts/{postId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Following - authenticated users can read anyone's following list, but only write their own
    match /users/{userId}/following/{followedUserId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Followers - anyone can read; only the follower themselves can add/remove their entry
    match /users/{userId}/followers/{followerId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(followerId);
    }

    // Notifications - users can only read/update/delete their own; any auth user can create
    // (needed so follow/like actions can send notifications to other users)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId != null;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Contests - anyone authenticated can read; admins/system create contest docs
    match /contests/{contestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Any user can initialise today's contest doc
      allow update: if isAuthenticated(); // Vote counts updated via transactions
    }

    // Contest entries - authenticated users can read all; create own
    match /contests/{contestId}/entries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated(); // Vote count increments via transaction
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Contest votes - per-entry voter subcollection
    match /votes/{entryId}/voters/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
